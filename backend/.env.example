APP_NAME=Relay Messenger
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://relay:relay_password@postgres:5432/relay
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-access-secret-at-least-32-bytes-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-bytes-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_RESET_TOKEN_IN_RESPONSE=false
PASSWORD_RESET_EMAIL_ENABLED=false
PASSWORD_RESET_URL=http://localhost:8100/reset-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8100,https://localhost,http://10.0.2.2:8000,http://100.106.107.54:5173,http://100.106.107.54:8100,capacitor://localhost,ionic://localhost
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
ENCRYPTION_ACTIVE_KEY_ID=v1
ENCRYPTION_KEYS={"v1":"REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY"}
PUSH_NOTIFICATIONS_ENABLED=false
METRICS_ENABLED=false
METRICS_BEARER_TOKEN=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
