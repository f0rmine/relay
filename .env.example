JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-bytes-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8100,https://localhost,http://10.0.2.2:8000,http://100.106.107.54:5173,http://100.106.107.54:8100,capacitor://localhost,ionic://localhost
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
PUSH_NOTIFICATIONS_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
